{
  "name": "user-service",
  "version": "1.0.2",
  "description": "Omnixys User Service",
  "author": {
    "name": "Caleb Gyamfi",
    "email": "caleb@omnixys.com",
    "url": "https://omnixys.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/omnixys/user-service.git"
  },
  "bugs": {
    "url": "https://github.com/omnixys/user-service/issues"
  },
  "homepage": "https://omnixys.com",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "private": false,
  "engines": {
    "node": ">=25.8.2",
    "pnpm": ">=11.1.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo",
    "build": "pnpm run clean && nest build",
    "format": "prettier --cache --write \"src/**/*.{ts,js,json,prisma,md,yaml}\"",
    "format:test": "prettier --cache --write \"src/**/*.{ts,js,json,prisma,md,yaml}\" \"__tests__/**/*.ts\"",
    "format:check": "prettier --cache --check \"src/**/*.{ts,js,json,prisma,md,yaml,yml}\" \"__test__/**/*.ts\"",
    "start": "pnpm nest start",
    "dev": "pnpm run clean && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config ./jest-e2e.json --maxWorkers=4 --coverage",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e:debug": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand --detectOpenHandles --config ./jest-e2e.json",
    "test:e2e2": "jest --config ./jest-e2e.json",
    "test:e2e": "NODE_OPTIONS='--experimental-vm-modules' jest --config ./jest-e2e.json --passWithNoTests",
    "typedoc": "typedoc",
    "depcheck": "depcheck",
    "test:login": "pnpm test -- __tests__/e2e/user/user.login.e2e-spec.ts",
    "test:signup": "pnpm test -- __tests__/e2e/user/user.signup.e2e-spec.ts",
    "test:user": "pnpm test -- __tests__/e2e/user/user.user.e2e-spec.ts",
    "test:admin": "pnpm test -- __tests__/e2e/user/user.admin.e2e-spec.ts",
    "prepare": "husky",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:push": "prisma db push",
    "prisma:pull": "prisma db pull",
    "prisma:reset:locale": "prisma migrate reset --force && prisma migrate dev && tsx prisma/seed.locale.ts",
    "reset": "prisma migrate reset --force && prisma migrate dev && tsx prisma/seed.locale.ts",
    "generate": "pnpm prisma format && pnpm prisma validate && prisma generate",
    "release": "semantic-release",
    "deps:audit": "tsx scripts/dependency-audit.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@apollo/subgraph": "^2.13.3",
    "@as-integrations/fastify": "^3.1.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/platform-fastify": "^11.1.17",
    "@nestjs/terminus": "^11.1.1",
    "@omnixys/cache": "file:../../packages/ts/cache",
    "@omnixys/context": "file:../../packages/ts/context",
    "@omnixys/graphql": "file:../../packages/ts/graphql",
    "@omnixys/kafka": "file:../../packages/ts/kafka",
    "@omnixys/logger": "file:../../packages/ts/logger",
    "@omnixys/observability":"file:../../packages/ts/observability",
    "@omnixys/security": "file:../../packages/ts/security",
    "@omnixys/shared": "file:../../packages/ts/shared",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "argon2": "^0.44.0",
    "cfonts": "^3.3.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dotenv": "^17.3.1",
    "fastify": "5.8.5",
    "kafkajs": "^2.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@prisma/extension-accelerate": "^3.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.15.21",
    "@tsconfig/node23": "^23.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.15",
    "@types/supertest": "^6.0.3",
    "@nestjs/testing": "^11.1.17",
    "chalk": "^5.6.2",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sort-imports": "^1.8.11",
    "prisma": "^7.6.0",
    "semantic-release": "^25.0.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "pnpm": {
    "overrides": {
      "fastify": "5.8.5"
    }
  }
}
