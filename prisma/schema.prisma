generator client {
  provider = "prisma-client"
  output   = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
  schemas  = ["user"]
}

/// ------------------------------------------------------------
/// USER SERVICE SCHEMA
/// ------------------------------------------------------------
model User {
  id       String @id @default(cuid()) @map("id")
  username String @unique @map("username")

  userType     UserType      @map("user_type")
  status       PersonStatus  @default(ACTIVE) @map("status")
  customer     Customer?
  employee     Employee?
  personalInfo PersonalInfo?

  contacts Contact[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([userType])
  @@index([status, userType])
  @@index([createdAt])
  @@map("user")
  @@schema("user")
}

/// ------------------------------------------------------------
/// PERSON SERVICE SCHEMA
/// ------------------------------------------------------------
model PersonalInfo {
  id    String @id @map("id")
  email String @unique @map("email")

  firstName     String             @map("first_name")
  lastName      String             @map("last_name")
  birthDate     DateTime?          @map("birth_date")
  gender        GenderType?        @map("gender")
  maritalStatus MaritalStatusType? @map("marital_status")

  phoneNumbers PhoneNumber[]

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([lastName])
  @@index([firstName, lastName])
  @@map("personal_info")
  @@schema("user")
}

/// ------------------------------------------------------------
/// CUSTOMER (FACHLICHE ERWEITERUNG)
/// ------------------------------------------------------------

model Customer {
  id String @id @map("id")

  subscribed Boolean    @default(false)
  state      StatusType @map("customer_state")

  contactOptions ContactOptionsType[] @map("contact_options")

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  customerInterests CustomerInterest[]

  @@index([state])
  @@index([subscribed])
  @@map("customer")
  @@schema("user")
}

/// ------------------------------------------------------------
/// EMPLOYEE (FACHLICHE ERWEITERUNG)
/// ------------------------------------------------------------

model Employee {
  id String @id @map("id")

  department String?   @map("department")
  position   String?   @map("position")
  role       String?   @map("role")
  salary     Float?    @map("salary")
  hireDate   DateTime? @map("hire_date")
  isExternal Boolean   @default(false) @map("is_external")

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([department])
  @@index([role])
  @@index([isExternal])
  @@map("employee")
  @@schema("user")
}

model PhoneNumber {
  id     String @id @default(cuid()) @map("id")
  infoId String @map("info_id")

  number      String          @map("number")
  type        PhoneNumberType @map("type")
  label       String?         @map("label")
  isPrimary   Boolean         @default(false) @map("is_primary")
  countryCode String          @map("country_code")

  user PersonalInfo @relation(fields: [infoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([countryCode, number])
  @@index([infoId])
  @@index([infoId, isPrimary])
  @@map("phone_number")
  @@schema("user")
}

/// ------------------------------------------------------------
/// CONTACTS (PERSON ↔ PERSON)
/// ------------------------------------------------------------

model Contact {
  id        String @id @default(cuid()) @map("id")
  userId    String @map("user_id")
  contactId String @map("contact_id")

  relationship    RelationshipType @map("relationship")
  withdrawalLimit Int              @default(0)
  emergency       Boolean          @default(false)

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, contactId])
  @@index([userId])
  @@index([emergency])
  @@map("contact")
  @@schema("user")
}

model InterestCategory {
  id   String              @id @default(cuid())
  key  InterestCategoryKey @unique // e.g. FINANCE, LIFESTYLE
  name String
  icon String?

  description String?
  interests   Interest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("interest_category")
  @@schema("user")
}

model Interest {
  id         String      @id @default(cuid())
  key        InterestKey @unique
  name       String
  categoryId String
  icon       String?

  category InterestCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  customers CustomerInterest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@map("interest")
  @@schema("user")
}

model CustomerInterest {
  id         String @id @default(cuid())
  customerId String
  interestId String

  // Optional future attributes:
  level     Int? // e.g. intensity 1–5
  isPrimary Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  interest Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([customerId, interestId], name: "customerId_interestId")
  @@index([interestId])
  @@map("customer_interest")
  @@schema("user")
}

/// ------------------------------------------------------------
/// ENUMS
/// ------------------------------------------------------------
enum UserType {
  CUSTOMER
  EMPLOYEE
  GUEST

  @@schema("user")
}

enum PhoneNumberType {
  WHATSAPP
  MOBILE
  PRIVATE
  WORK
  HOME
  OTHER

  @@schema("user")
}

enum PersonStatus {
  ACTIVE
  DISABLED
  DELETED
  INACTIVE
  BLOCKED
  CLOSED

  @@schema("user")
}

enum GenderType {
  MALE
  FEMALE
  DIVERSE
  UNKNOWN

  @@schema("user")
}

enum RelationshipType {
  FAMILY
  FRIEND
  PARTNER
  COLLEAGUE
  OTHER
  BUSINESS_PARTNER
  RELATIVE
  PARENT
  SIBLING
  CHILD
  COUSIN

  @@schema("user")
}

enum MaritalStatusType {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED

  @@schema("user")
}

enum StatusType {
  ACTIVE
  INACTIVE
  BLOCKED
  PENDING
  SUSPENDED
  CLOSED

  @@schema("user")
}

enum InterestKey {
  BANK_PRODUCTS_AND_SERVICES
  TECHNOLOGY_AND_INNOVATION
  FINANCIAL_EDUCATION_AND_COUNSELING
  SUSTAINABLE_FINANCE
  INVESTMENTS
  SAVING_AND_FINANCE
  CREDIT_AND_DEBT
  REAL_ESTATE
  INSURANCE

  // Lifestyle
  TRAVEL

  // Music
  CLASSIC
  ROCK
  HIPHOP
  RAP

  // Sports
  FOOTBALL
  SOCCER
  RUGBY
  BASKETBALL

  @@map("interest_key")
  @@schema("user")
}

enum InterestCategoryKey {
  SPORTS
  MUSIC
  FINANCE
  REAL_ASSETS
  TECHNOLOGY
  LIFESTYLE

  @@schema("user")
}

enum ContactOptionsType {
  EMAIL
  PHONE
  SMS
  WHATSAPP
  LETTER

  @@schema("user")
}
