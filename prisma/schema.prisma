generator client {
  provider = "prisma-client"
  output   = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
  schemas  = ["user"]
}

/// ------------------------------------------------------------
/// USER SERVICE SCHEMA
/// ------------------------------------------------------------
model User {
  id            String        @id @default(cuid()) @map("id")
  username      String        @unique @map("username")
  firstName     String        @map("first_name")
  lastName      String        @map("last_name")
  email         String        @unique @map("email")
  phoneNumbers  PhoneNumber[] @relation("UserPhoneNumbers")
  ticketIds     String[]      @map("ticket_ids")
  invitationIds String[]      @map("invitation_ids")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([username, email])
  @@map("user")
  @@schema("user")
}

model PhoneNumber {
  id        String          @id @default(cuid()) @map("id")
  number    String          @map("number")
  type      PhoneNumberType @map("type")
  user      User            @relation("UserPhoneNumbers", fields: [userId], references: [id], onDelete: Cascade)
  userId    String          @map("user_id")
  label     String?         @map("label")
  isPrimary Boolean         @default(false) @map("is_primary")

  @@map("phone_number")
  @@schema("user")
}

enum PhoneNumberType {
  WHATSAPP
  MOBILE
  PRIVATE
  WORK
  HOME
  OTHER

  @@schema("user")
}
