generator client {
  provider = "prisma-client"
  output   = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
  schemas  = ["user"]
}

/// ------------------------------------------------------------
/// USER SERVICE SCHEMA
/// ------------------------------------------------------------
model User {
  id       String @id @default(cuid()) @map("id")
  username String @unique @map("username")

  ticketIds     String[] @map("ticket_ids")
  invitationIds String[] @map("invitation_ids")

  userType     UserType      @map("user_type")
  status       PersonStatus  @default(ACTIVE) @map("status")
  customer     Customer?
  employee     Employee?
  personalInfo PersonalInfo?

  addresses         Address[]
  contacts          Contact[]
  securityQuestions SecurityQuestion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user")
  @@schema("user")
}

/// ------------------------------------------------------------
/// PERSON SERVICE SCHEMA
/// ------------------------------------------------------------
model PersonalInfo {
  id    String @id @map("id")
  email String @unique @map("email")

  firstName     String             @map("first_name")
  lastName      String             @map("last_name")
  birthDate     DateTime?          @map("birth_date")
  gender        GenderType?        @map("gender")
  maritalStatus MaritalStatusType? @map("marital_status")

  phoneNumbers PhoneNumber[]

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("personal_info")
  @@schema("user")
}

/// ------------------------------------------------------------
/// ADDRESS
/// ------------------------------------------------------------
model Address {
  id     String @id @default(cuid()) @map("id")
  userId String @map("user_id")

  street         String  @map("street")
  houseNumber    String  @map("house_number")
  zipCode        String  @map("zip_code")
  city           String  @map("city")
  state          String? @map("state")
  country        String  @map("country")
  additionalInfo String? @map("additional_info")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("address")
  @@schema("user")
}

/// ------------------------------------------------------------
/// CUSTOMER (FACHLICHE ERWEITERUNG)
/// ------------------------------------------------------------

model Customer {
  id String @id @map("id")

  tierLevel     Int                @map("tier_level")
  subscribed    Boolean            @default(false)
  maritalStatus MaritalStatusType?
  state         StatusType         @map("customer_state")

  interests      InterestType[]       @map("interests")
  contactOptions ContactOptionsType[] @map("contact_options")

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("customer")
  @@schema("user")
}

/// ------------------------------------------------------------
/// EMPLOYEE (FACHLICHE ERWEITERUNG)
/// ------------------------------------------------------------

model Employee {
  id String @id @map("id")

  department String?
  position   String?
  role       String?
  salary     Float?
  hireDate   DateTime?
  isExternal Boolean   @default(false)

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("employee")
  @@schema("user")
}

model PhoneNumber {
  id     String @id @default(cuid()) @map("id")
  infoId String @map("info_id")

  number    String          @map("number")
  type      PhoneNumberType @map("type")
  label     String?         @map("label")
  isPrimary Boolean         @default(false) @map("is_primary")

  user PersonalInfo @relation(fields: [infoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("phone_number")
  @@schema("user")
}

model SecurityQuestion {
  id String @id @default(cuid()) @map("id")

  question   String @map("question")
  answerHash String @map("answer_hash")

  attempts Int       @default(0) @map("attempts")
  lockedAt DateTime? @map("locked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@unique([userId, question])
  @@map("security_question")
  @@schema("user")
}

model PasswordReset {
  id        String    @id @default(cuid()) @map("id")
  userId    String    @map("user_id")
  userEmail String    @map("user_email")
  token     String    @unique @map("token")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  ipAddress String?   @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@map("password_reset")
  @@schema("user")
}

/// ------------------------------------------------------------
/// CONTACTS (PERSON ↔ PERSON)
/// ------------------------------------------------------------

model Contact {
  id        String @id @default(cuid()) @map("id")
  userId    String @map("user_id")
  contactId String @map("contact_id")

  relationship    RelationshipType @map("relationship")
  withdrawalLimit Int              @default(0)
  emergency       Boolean          @default(false)

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, contactId])
  @@map("contact")
  @@schema("user")
}

/// ------------------------------------------------------------
/// ENUMS
/// ------------------------------------------------------------
enum UserType {
  CUSTOMER
  EMPLOYEE
  GUEST

  @@schema("user")
}

enum PhoneNumberType {
  WHATSAPP
  MOBILE
  PRIVATE
  WORK
  HOME
  OTHER

  @@schema("user")
}

enum PersonStatus {
  ACTIVE
  DISABLED
  DELETED

  @@schema("user")
}

enum GenderType {
  MALE
  FEMALE
  DIVERSE
  UNKNOWN

  @@schema("user")
}

enum RelationshipType {
  FAMILY
  FRIEND
  PARTNER
  COLLEAGUE
  OTHER

  @@schema("user")
}

enum MaritalStatusType {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED

  @@schema("user")
}

enum StatusType {
  ACTIVE
  INACTIVE
  BLOCKED

  @@schema("user")
}

enum InterestType {
  SPORTS
  MUSIC
  TRAVEL
  TECHNOLOGY
  OTHER

  @@schema("user")
}

enum ContactOptionsType {
  EMAIL
  PHONE
  SMS
  WHATSAPP

  @@schema("user")
}
